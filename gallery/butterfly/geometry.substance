-- Theorem: butterfly
Point O, R, P, Q, M, A, B, C, D, X, Y

Circle c_O_R := CircleR(O, R)
Segment PQ := Chord(c_O_R, P, Q)
Segment AB := Chord(c_O_R, A, B)
Segment CD := Chord(c_O_R, C, D)
Segment AD := Chord(c_O_R, A, D)
Segment BC := Chord(c_O_R, B, C)
Segment XY := Segment(X, Y)

-- Constraints:
Midpoint(PQ, M)
On(M, AB)
On(M, CD)
On(X, PQ)
On(X, AD)
On(Y, PQ)
On(Y, BC)
Midpoint(XY, M)

-- Labels:
AutoLabel O, R, P, Q, M, A, B, C, D, X, Y
