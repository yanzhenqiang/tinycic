// Breakage Detection Test File
// 破坏性检查测试文件
//
// 这些测试故意使用无效/错误的证明方法，用于验证类型检查器
// 能够正确检测并拒绝它们。如果这些"错误"的证明通过了检查，
// 就说明系统有漏洞。

namespace BreakageTest

-- ============================================
-- Test 1: 无效 tactic 应该被拒绝
-- ============================================
-- 下面的定理使用了不存在的 'rfl' standalone tactic
-- 在严格模式下这应该报错

-- theorem test_invalid_rfl : Nat :=
--   by
--     rfl  -- 这应该被拒绝！rfl 不是合法的 standalone tactic

-- ============================================
-- Test 2: 类型不匹配的 exact 应该被拒绝
-- ============================================
-- exact True 不应该能证明 Nat 类型的目标

-- theorem test_type_mismatch : Nat :=
--   by
--     exact True  -- 这应该被拒绝！True 不是 Nat

-- ============================================
-- Test 3: 未知的变量引用应该被拒绝
-- ============================================

-- theorem test_unknown_var : Nat :=
--   by
--     exact unknown_var_name  -- 这应该被拒绝！变量不存在

-- ============================================
-- Test 4: 正确的 sorry 使用应该被接受
-- ============================================
-- 这是合法的未完成证明标记

test_sorry_accepted : Nat :=
  by
    sorry  -- 这是合法的：明确标记未完成

-- ============================================
-- Test 5: 有效的证明应该通过
-- ============================================

test_valid_proof (n : Nat) : Nat :=
  by
    exact n  -- 这是合法的：使用参数

-- ============================================
-- 破坏性检查说明
-- ============================================
-- 这些测试确保：
-- 1. 严格模式下，未知 tactic 会立即报错
-- 2. 类型检查器能捕获类型不匹配
-- 3. 只有显式的 sorry 才能用于跳过证明
-- 4. 不能通过拼写错误或近似 tactic 来绕过检查
--
-- 如果系统有任何漏洞，这些测试会暴露出来。

end BreakageTest
