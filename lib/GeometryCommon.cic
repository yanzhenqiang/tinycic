-- =====================================================================
-- Perpendicular existence (derived from the axiom)
-- =====================================================================

-- Through any point P there exists a line perpendicular to a given line l.
theorem perpendicular_exists_thm : forall (l : Line) (P : Point),
  exists (m : Line), And (on_line P m) (perpendicular l m) := by
  intro l
  intro P
  exact (perpendicular_exists l P)

